{
  "folder": ".obsidian/templates",
  "dateFormat": "YYYY-MM-DD",
  "timeFormat": "HH:mm",
  "template": {
    "상호작용-기록-템플릿.md": {
      "description": "사람과의 상호작용을 체계적으로 기록",
      "tags": ["interaction", "memory"],
      "autoOpen": true
    },
    "프로젝트-진행-기록-템플릿.md": {
      "description": "프로젝트 진행 상황을 정기적으로 기록",
      "tags": ["project", "progress"],
      "autoOpen": true
    }
  },
  "prompt": true,
  "autoTrigger": false,
  "trigger": "@",
  "openNewFile": true,
  "openNewFileDirection": "right",
  "openNewFileOnWrite": false
}