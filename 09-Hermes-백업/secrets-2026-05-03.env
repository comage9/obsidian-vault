# Hermes Agent — API 키 및 토큰 (.env)
# 생성: 2026-05-03
# ⚠️ 실제 키는 별도 보관 — 이 파일은 템플릿임

# ============================================
# GitHub
# ============================================
GITHUB_TOKEN={YOUR_GITHUB_TOKEN}

# ============================================
# OpenRouter (교체 필요)
# ============================================
OPENROUTER_API_KEY={YOUR_OPENROUTER_API_KEY}

# ============================================
# MiniMax
# ============================================
MINIMAX_API_KEY={YOUR_MINIMAX_API_KEY}

# ============================================
# GoClaw
# ============================================
GOCLAW_DB_DSN=postgres://postgres:{password}@localhost:5432/goclaw?sslmode=disable
GOCLAW_GATEWAY_TOKEN={YOUR_GATEWAY_TOKEN}
GOCLAW_ENCRYPTION_KEY={YOUR_ENCRYPTION_KEY}
GOCLAW_TELEGRAM_BOT_TOKEN={YOUR_TELEGRAM_BOT_TOKEN}

# ============================================
# Kiwoom (주식 봇)
# ============================================
KIWOOM_APP_KEY={YOUR_KIWOOM_APP_KEY}
KIWOOM_SECRET_KEY={YOUR_KIWOOM_SECRET_KEY}
